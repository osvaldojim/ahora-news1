{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "ahoranews.news"}],
      "destination": "https://www.ahoranews.news/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "ahora-news1.vercel.app"}],
      "destination": "https://www.ahoranews.news/$1",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/api/news", "dest": "/api/news.js" },
    { "src": "/api/publish", "dest": "/api/publish.js" },
    { "src": "/api/trading", "dest": "/api/trading.js" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/ads.txt", "dest": "/ads.txt" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
